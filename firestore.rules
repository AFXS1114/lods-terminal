rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    /**
     * @description GLOBAL TERMINAL ACCESS CONTROL
     * PROTOTYPE MODE: FULL PUBLIC ACCESS
     * 
     * This configuration allows all read and write operations without authentication.
     * This is intended for rapid prototyping and initial system orchestration.
     */
    
    match /{document=**} {
      allow read, write: if true;
    }
  }
}