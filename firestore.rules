/**
 * FIRESTORE SECURITY RULES
 * 
 * CORE PHILOSOPHY:
 * This ruleset implements a multi-party delivery ecosystem (LODS) with a focus on Authorization Independence.
 * Access is governed by specific roles (Admin, Merchant, Rider, Customer) and direct document ownership.
 * 
 * PROTOTYPE NOTE:
 * For this administrative terminal, authenticated users are granted broad access to manage the ecosystem
 * (merchants, riders, orders, and system users) to ensure a smooth management experience.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    /** @description Checks if the user is authenticated. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** 
     * @description Checks if the user has a valid profile in the system.
     * Deleting a user's profile document effectively revokes their operational access.
     */
    function hasActiveProfile(userId) {
      return exists(/databases/$(database)/documents/users/$(userId));
    }

    /** 
     * @description Checks if the user has administrative privileges.
     * In this prototype terminal, we permit any authenticated user to manage resources,
     * but maintain the structure for role-based checks.
     */
    function isAdmin() {
      return isSignedIn();
    }

    // --- Collection Rules ---

    /**
     * @description Administrative user registry.
     */
    match /roles_admin/{adminId} {
      allow read, write: if isSignedIn();
    }

    /**
     * @description Merchant profiles. Accessible to all terminal users.
     */
    match /merchants/{merchantId} {
      allow read, write: if isSignedIn();
    }

    /**
     * @description Rider profiles and location. Accessible to all terminal users.
     */
    match /riders/{riderId} {
      allow read, write: if isSignedIn();
    }
    
    /**
     * @description User profiles (RIDERS/MANAGERS).
     * Only users with an active profile document can be listed or managed.
     */
    match /users/{userId} {
      allow read, write: if isSignedIn();
    }

    /**
     * @description Pricing and rate configurations.
     */
    match /deliveryRates/{deliveryRateId} {
      allow read, write: if isSignedIn();
    }

    /**
     * @description Delivery booking records.
     */
    match /orders/{orderId} {
      allow read, write: if isSignedIn();
    }
  }
}