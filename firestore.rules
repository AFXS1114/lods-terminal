rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    /**
     * @description GLOBAL TERMINAL ACCESS CONTROL
     * PROTOTYPE MODE: Public access enabled for rapid development and initial setup.
     * This allows any user to read and write to all collections, including orders,
     * merchants, and riders, without requiring authentication.
     */
    match /{document=**} {
      allow read, write: if true;
    }
  }
}